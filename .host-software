# .host-software — the Where room recipe (STRUCTURE.md).
#
# One [software "<name>"] stanza per component: source URL, pinned SHA, and the
# canonical branch. `host-lifecycle software --materialize` realises each as a bare
# store plus worktrees under software/<name>/ (gitignored); the recorded pin is the
# reproducibility anchor. `software --check` audits each worktree against its pin.

[software "adlib_gold"]
	url          = https://github.com/slartibardfast/adlib_gold.git
	pin          = 523f2bde69a7b85b18650fe3a7eab9ee6db7ec02
	branch       = main
	deploy       = main
	deps-bundle  = https://github.com/slartibardfast/ddk.git f60af3fd65b53b67176499d9959adc1235cb1a1d3024c0adb6b7bd3c2fadb902

# Dual-hosted (call/0009): one source pin, built on two hosts, byte-identical. Both
# run the same VC6 binaries over identical C:\ paths, so the artifact hash matches.
[build "adlib_gold" "linux"]
	toolchain    = win2k-ddk-vc6
	build        = ./build.sh
	attest-host  = linux
	artifact     = adlibgold.sys e5993fceb436057886ac99b2b011672fd63f8932be8df63ecf93f053b716060e

[build "adlib_gold" "windows"]
	toolchain    = win2k-ddk-vc6
	build        = build.bat
	attest-host  = windows
	artifact     = adlibgold.sys e5993fceb436057886ac99b2b011672fd63f8932be8df63ecf93f053b716060e
